# ── Supabase ───────────────────────────────────────────────────────────────────
# From Supabase Dashboard → Project Settings → API

# Public (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...YOUR_ANON_KEY...

# Server-only (NEVER expose to browser or commit to git)
SUPABASE_SERVICE_ROLE_KEY=eyJ...YOUR_SERVICE_ROLE_KEY...

# ── Password Security ──────────────────────────────────────────────────────────
# Used to XOR-obfuscate stored passwords before DB write.
# Change this to a strong random string (32+ chars). Keep it secret.
# ⚠️ Phase 1: XOR obfuscation. Phase 2+: replace with AES-256-GCM + KMS.
PASSWORD_OBFUSCATION_KEY=change-this-to-a-long-random-secret-string-32-chars

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
# Phase 2: Used for sending credential emails to new users
# SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY
# SENDGRID_FROM_EMAIL=noreply@nudgeable.ai
# SENDGRID_CREDENTIAL_TEMPLATE_ID=d-YOUR_TEMPLATE_ID

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
